// Prisma Schema for PDME Backend
// Database: PostgreSQL with TimescaleDB extension

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Disasters Table - Core disaster events
model Disaster {
  id            Int      @id @default(autoincrement())
  type          String   // 'flood', 'earthquake', 'fire', 'drought', 'meteorological', 'geophysical', 'climatological'
  eventDate     DateTime @map("event_date")
  location      String?
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  severity      String?
  deaths        Int?
  affected      Int?
  economicLossUsd BigInt? @map("economic_loss_usd")
  province      String?
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  floodEvent     FloodEvent?
  earthquakeEvent EarthquakeEvent?

  @@index([type])
  @@index([eventDate])
  @@index([province])
  @@map("disasters")
}

// Flood Events - Specific flood disaster data
model FloodEvent {
  id            Int      @id @default(autoincrement())
  disasterId    Int?     @unique @map("disaster_id")
  waterLevel    Decimal? @map("water_level") @db.Decimal(8, 2)
  damLevels     Json?    @map("dam_levels") // {tarbela: 1491.26, mangla: 1214.70, etc.}
  affectedAreas String[] @map("affected_areas")
  riverName     String?  @map("river_name")
  floodRate     Decimal? @map("flood_rate") @db.Decimal(5, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  disaster      Disaster? @relation(fields: [disasterId], references: [id], onDelete: Cascade)

  @@map("flood_events")
}

// Earthquake Events - Specific earthquake disaster data
model EarthquakeEvent {
  id            Int      @id @default(autoincrement())
  disasterId    Int?     @unique @map("disaster_id")
  magnitude     Decimal? @db.Decimal(4, 2)
  depth         Decimal? @db.Decimal(8, 2)
  epicenter     String?
  affectedRadius Decimal? @map("affected_radius") @db.Decimal(8, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  disaster      Disaster? @relation(fields: [disasterId], references: [id], onDelete: Cascade)

  @@map("earthquake_events")
}

// Weather Data - Time-series data for weather monitoring
model WeatherData {
  id            Int      @id @default(autoincrement())
  time          DateTime
  location      String
  latitude      Decimal  @db.Decimal(10, 8)
  longitude     Decimal  @db.Decimal(11, 8)
  temperature   Decimal? @db.Decimal(5, 2)
  precipitation Decimal? @db.Decimal(8, 2)
  humidity      Decimal? @db.Decimal(5, 2)
  windSpeed     Decimal? @map("wind_speed") @db.Decimal(5, 2)
  pressure      Decimal? @db.Decimal(7, 2)
  evapotranspiration Decimal? @db.Decimal(8, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([time])
  @@index([location])
  @@index([latitude, longitude])
  @@map("weather_data")
}

// Predictions - ML Model Results
model Prediction {
  id            Int      @id @default(autoincrement())
  type          String   // 'flood', 'fire'
  location      String
  latitude      Decimal  @db.Decimal(10, 8)
  longitude     Decimal  @db.Decimal(11, 8)
  predictionDate DateTime @map("prediction_date")
  probability   Decimal  @db.Decimal(5, 4) // 0.0000 to 1.0000
  predictionValue Int?    @map("prediction_value") // 0 or 1
  modelVersion  String?  @map("model_version")
  features      Json?    // Store weather_data and other features
  weatherData   Json?    @map("weather_data")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([location])
  @@index([predictionDate])
  @@map("predictions")
}

// Emergency Contacts
model EmergencyContact {
  id           Int      @id @default(autoincrement())
  organization String
  province     String?
  phone        String?
  email        String?
  category     String?  // 'ndma', 'pdma', 'rescue', 'hospital', 'police', 'fire'
  address      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([province])
  @@index([category])
  @@map("emergency_contacts")
}

// Relief Stocks
model ReliefStock {
  id          Int      @id @default(autoincrement())
  item        String
  quantity    Int
  unit        String? // 'kg', 'pieces', 'liters', 'boxes'
  location    String
  province    String?
  lastUpdated DateTime @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([province])
  @@index([location])
  @@map("relief_stocks")
}

// Provinces
model Province {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  code             String?  @unique // 'PK-PB', 'PK-SD', etc.
  latitude         Decimal? @db.Decimal(10, 8)
  longitude        Decimal? @db.Decimal(11, 8)
  vulnerabilityIndex Decimal? @map("vulnerability_index") @db.Decimal(5, 2)
  population       BigInt?
  area             Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("provinces")
}

// Provincial Victims Data - Historical victim data by province
model ProvincialVictim {
  id          Int      @id @default(autoincrement())
  province    String
  year        Int
  deaths      Int?
  affected    Int?
  displaced   Int?
  economicLoss BigInt? @map("economic_loss")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([province, year])
  @@index([province])
  @@index([year])
  @@map("provincial_victims")
}

// Climate Data - Climate trends and indicators
model ClimateData {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int?
  province    String?
  temperature Decimal? @db.Decimal(5, 2)
  precipitation Decimal? @db.Decimal(8, 2)
  humidity    Decimal? @db.Decimal(5, 2)
  trend       String?  // 'increasing', 'decreasing', 'stable'
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([year])
  @@index([province])
  @@map("climate_data")
}

// NDMA Data - NDMA vulnerability and alert data
model NDMAData {
  id          Int      @id @default(autoincrement())
  province    String?
  district    String?
  vulnerabilityLevel String? @map("vulnerability_level")
  alertLevel  String? @map("alert_level")
  riskFactors Json?   @map("risk_factors")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([province])
  @@index([district])
  @@map("ndma_data")
}

// Active Incidents - Real-time Monsoon 2025 incidents
model ActiveIncident {
  id              String   @id // e.g., "INC-2025-001"
  type            String   // 'Riverine Flood', 'Flash Flood', 'Urban Flooding', 'GLOF'
  province        String
  district        String
  severity        String   // 'Critical', 'High', 'Medium', 'Low'
  status          String   // 'Active', 'Monitoring', 'Resolved'
  affected        Int      @default(0)
  casualties      Int      @default(0)
  injured         Int      @default(0)
  evacuated       Int      @default(0)
  responseTeams   Int      @default(0) @map("response_teams")
  reliefCamps     Int      @default(0) @map("relief_camps")
  latitude        Decimal  @db.Decimal(10, 8)
  longitude       Decimal  @db.Decimal(11, 8)
  startDate       DateTime @map("start_date")
  lastUpdate      DateTime @map("last_update")
  description     String?  @db.Text
  incidentCommander String? @map("incident_commander")
  responseActions Json?    @map("response_actions") // Array of strings
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([province])
  @@index([district])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@map("active_incidents")
}

// Response Teams - Deployed NDMA/PDMA response teams
model ResponseTeam {
  id              String   @id // e.g., "RT-PB-001"
  name            String
  province        String
  currentLocation String   @map("current_location")
  status          String   // 'Deployed', 'Active', 'Standby', 'Returned'
  personnel       Int
  equipment       Json     // Array of equipment strings
  mission         String?
  latitude        Decimal  @db.Decimal(10, 8)
  longitude       Decimal  @db.Decimal(11, 8)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([province])
  @@index([status])
  @@index([currentLocation])
  @@map("response_teams")
}

// Provincial Vulnerabilities - Monsoon 2025 risk assessment
model ProvincialVulnerability {
  id                Int      @id @default(autoincrement())
  province          String   @unique
  riskLevel         String   @map("risk_level") // 'Very High', 'High', 'Medium', 'Low'
  vulnerableDistricts Int     @map("vulnerable_districts")
  rainfallOutlook   String?  @map("rainfall_outlook") @db.Text
  floodTypes        Json     @map("flood_types") // Array of strings
  keyThreats        Json     @map("key_threats") // Array of strings
  highRiskDistricts Json     @map("high_risk_districts") // Array of strings
  pdmaContact       Json     @map("pdma_contact") // Object with name, phone, email, eoc
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("provincial_vulnerabilities")
}

// NDMA Warehouses - Relief stock warehouses
model NDMAWarehouse {
  id            String   @id // e.g., "WH-ISB"
  name          String
  location      String
  type          String   // 'Central', 'Regional'
  latitude      Decimal  @db.Decimal(10, 8)
  longitude     Decimal  @db.Decimal(11, 8)
  capacity      String?
  currentStock  Json     @map("current_stock") // Object with stock items
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([location])
  @@index([type])
  @@map("ndma_warehouses")
}

// High Risk Districts - District-level vulnerability tracking
model HighRiskDistrict {
  id              Int      @id @default(autoincrement())
  district        String
  province        String
  floodType       String   @map("flood_type") // 'Riverine', 'Flash', 'Urban', 'GLOF'
  riskLevel       String   @map("risk_level") // 'Very High', 'High', 'Medium'
  riskFactors     Json?    @map("risk_factors") // Array of risk factors
  earlyWarningStatus String? @map("early_warning_status") // 'Active', 'Monitoring', 'Inactive'
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([district, province])
  @@index([province])
  @@index([floodType])
  @@index([riskLevel])
  @@map("high_risk_districts")
}

