    "calculation_method": "flood_rate = (number_of_documented_major_flood_events / 74 years)",
    "data_quality": "Based on documented major flood events from NDMA official records",
    "usage": "Map user coordinates to district using reverse geocoding, lookup flood_rate for model input",
    "note": "Rates represent historical flood frequency, not severity"
  },
  "default_values": {
    "unknown_district": 0.05,
    "no_data_available": 0.03,
    "urban_areas_general": 0.08,
    "mountainous_glof_areas": 0.12
  },
  "usage_instructions": {
    "step_1": "Get user coordinates (latitude, longitude)",
    "step_2": "Use reverse geocoding to get district name",
    "step_3": "Lookup district in appropriate province section",
    "step_4": "Return flood_rate value for model input",
    "step_5": "If district not found, use default_value based on region type"
  },
